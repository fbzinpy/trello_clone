generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // SIN url aquí - va config.ts
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}